{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build SafeWatch",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "FUNCTIONS/FINALS.cpp",
                "FUNCTIONS/ADMIN.cpp",
                "FUNCTIONS/USER.cpp",
                "FUNCTIONS/notification.cpp",
                "-luser32",
                "-o",
                "FUNCTIONS/SafeWatch.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build all SafeWatch source files into a single executable."
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "none",
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}